{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/Definition/1.0.0/schema.json",
  "description": "Root definition for a Plan artifact containing semantic model references and sheet declarations.",
  "type": "object",
  "required": [
    "$schema",
    "workloadItemName",
    "sheets"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "const": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/Definition/1.0.0/schema.json"
    },
    "workloadItemName": {
      "type": "string",
      "description": "User-facing name of the workload item."
    },
    "semanticModelReference": {
      "$ref": "#/definitions/SemanticModelReference"
    },
    "sheets": {
      "type": "array",
      "description": "List of sheets in the plan.",
      "items": {
        "$ref": "#/definitions/SheetReference"
      }
    },
    "cube": {
      "$ref": "#/definitions/CubeReference"
    },
    "appDBconnection": {
      "type": "string",
      "format": "uuid",
      "description": "Application database connection ID."
    },
    "appDBconnectionVariable": {
      "type": "string",
      "description": "Environment variable key for resolving application database connection ID."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "SemanticModelReference": {
      "type": "object",
      "description": "Reference to the semantic model backing this plan.",
      "required": [
        "recordGuid",
        "sourceType"
      ],
      "allOf": [
        {
          "oneOf": [
            {
              "required": [
                "connectionId"
              ]
            },
            {
              "required": [
                "connectionIdVariable",
                "connectionIdVariableName"
              ]
            }
          ]
        },
        {
          "oneOf": [
            {
              "required": [
                "semanticModelVariable",
                "semanticModelVariableName"
              ]
            },
            {
              "required": [
                "semanticModelId",
                "semanticModelName",
                "semanticModelWorkspaceId",
                "semanticModelWorkspaceName",
                "directLakeMode",
                "directQueryMode",
                "url"
              ]
            }
          ]
        }
      ],
      "properties": {
        "recordGuid": {
          "type": "string",
          "format": "uuid"
        },
        "connectionId": {
          "type": "string",
          "format": "uuid"
        },
        "connectionIdVariable": {
          "$ref": "https://developer.microsoft.com/json-schemas/fabric/common/connectionReference/1.0.0/schema.json#/definitions/ConnectionReferenceOrVar"
        },
        "connectionIdVariableName": {
          "type": "string"
        },
        "semanticModelId": {
          "type": "string",
          "format": "uuid"
        },
        "semanticModelVariable": {
          "$ref": "https://developer.microsoft.com/json-schemas/fabric/common/itemReference/1.0.0/schema.json#/definitions/ItemReferenceOrVar"
        },
        "semanticModelVariableName": {
          "type": "string"
        },
        "semanticModelName": {
          "type": "string"
        },
        "semanticModelWorkspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "semanticModelWorkspaceName": {
          "type": "string"
        },
        "directLakeMode": {
          "type": "boolean"
        },
        "directQueryMode": {
          "type": "boolean"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sourceType": {
          "type": "string",
          "enum": ["POWERTABLE", "INFOBRIDGE", "WORKLOAD"]
        },
        "artifactId": {
          "type": ["string", "null"]
        },
        "datasetRelations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "CubeReference": {
      "type": "object",
      "required": [
        "partitionRefIds"
      ],
      "properties": {
        "partitionRefIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "SheetReference": {
      "type": "object",
      "description": "A sheet declaration within the plan.",
      "required": [
        "displayName",
        "sheetType",
        "recordGuid"
      ],
      "properties": {
         "recordGuid": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the sheet record."
        },
        "displayName": {
          "type": "string",
          "description": "User-facing name of the sheet."
        },
        "sheetType": {
          "type": "string",
          "description": "The type of sheet.",
          "enum": [
            "PLANNING",
            "REPORTING",
            "POWERTABLE",
            "INFOBRIDGE",
            "SUPER_FILTER",
            "BI_REPORTING",
            "BI_ADHOC_ANALYSIS",
            "BI_DASHBOARD"
          ]
        },
        "isHidden": {
          "type": "boolean",
          "description": "Indicates if the sheet is hidden."
        },
        "order": {
          "type": "number",
          "description": "Order of the sheet within the report."
        },
        "workloadItemEntityVisuals": {
          "type": "array",
          "description": "List of visuals associated with the sheet.",
          "items": {
            "type": "object",
            "properties": {
              "visualType": {
                "type": "string",
                "description": "Type of the visual.",
                "enum": ["POWERTABLE", "PLANNING", "INFO_BRIDGE"]
              },
              "visualId": {
                "type": "string",
                "format": "uuid",
                "description": "Unique identifier for the visual."
              },
              "isEmbedded": {
                "type": "boolean",
                "description": "Indicates if the visual is embedded."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
