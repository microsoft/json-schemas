{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/connectedPlanning/infobridge/1.0.0/schema.json",
  "description": "InfoBridge configuration defining data sources, queries, transformation steps, and writeback destinations for connected planning.",
  "type": "object",
  "required": [
    "$schema",
    "sources"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "const": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/connectedPlanning/infobridge/1.0.0/schema.json"
    },
    "sources": {
      "title": "Sources",
      "description": "List of InfoBridge data sources.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Source"
      }
    },
    "queryGroups": {
      "title": "QueryGroups",
      "description": "Optional groupings of queries for organizational purposes.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/QueryGroup"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Source": {
      "title": "Source",
      "description": "An InfoBridge data source configuration.",
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "description": "The display name of the source.",
          "type": "string"
        },
        "type": {
          "description": "The source type. Supports known string or numeric codes.",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "PLANNING",
                "PARQUET",
                "APPEND",
                "MERGE",
                "CSV",
                "JSON",
                "XLSX",
                "SQL_SOURCE",
                "JOIN",
                "ENCRYPTED_PARQUET",
                "EDITABLE"
              ]
            },
            {
              "type": "integer",
              "enum": [
                10,
                20,
                30,
                40,
                50,
                60,
                70,
                80,
                170,
                220,
                230
              ]
            }
          ]
        },
        "visualId": {
          "description": "The visual identifier this source is associated with. Can be numeric internal ID or UUID in external definitions.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "format": "uuid"
            }
          ]
        },
        "meta": {
          "description": "Source metadata.",
          "oneOf": [
            {
              "$ref": "#/definitions/SourceMeta"
            },
            {
              "type": "string"
            }
          ]
        },
        "queries": {
          "description": "List of queries for this source.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Query"
          }
        },
        "dependentQueries": {
          "description": "List of dependent query GUIDs for join sources.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "SourceMeta": {
      "title": "SourceMeta",
      "description": "Metadata for a source or join configuration.",
      "type": "object",
      "properties": {
        "includeMeasures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "includeScenarios": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "queries": {
          "description": "Join query references (for join sources).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/JoinQueryReference"
          }
        },
        "joinType": {
          "description": "The join type (e.g, INNER, LEFT, etc.).",
          "type": "string"
        },
        "sql": {
          "description": "Optional SQL text for SQL source.",
          "type": "string"
        }
      }
    },
    "JoinQueryReference": {
      "title": "JoinQueryReference",
      "description": "A reference to a query used in a join.",
      "type": "object",
      "required": [
        "sourceName",
        "joinColumnName"
      ],
      "properties": {
        "queryId": {
          "description": "The GUID of the referenced query.",
          "type": "string"
        },
        "sourceId": {
          "description": "Internal numeric source/query identifier.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "sourceName": {
          "description": "The display name of the source query.",
          "type": "string"
        },
        "joinColumnName": {
          "description": "Column names used for the join.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "isBaseQuery": {
          "description": "Whether this is the base query in the join.",
          "type": "boolean"
        }
      },
      "oneOf": [
        {
          "required": [
            "queryId"
          ]
        },
        {
          "required": [
            "sourceId"
          ]
        }
      ]
    },
    "Query": {
      "title": "Query",
      "description": "An InfoBridge query definition.",
      "type": "object",
      "required": [
        "name",
        "queryId"
      ],
      "properties": {
        "name": {
          "description": "The display name of the query.",
          "type": "string"
        },
        "type": {
          "description": "The query type (string or numeric code).",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ]
        },
        "visualId": {
          "description": "The visual identifier (numeric internal ID or UUID in external definitions).",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "format": "uuid"
            }
          ]
        },
        "meta": {
          "description": "Query-level metadata.",
          "type": "object"
        },
        "queryId": {
          "description": "The unique GUID for this query.",
          "type": "string"
        },
        "transformationSteps": {
          "description": "Ordered list of transformation steps.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransformationStep"
          }
        },
        "writebackSettings": {
          "description": "Writeback settings for this query.",
          "$ref": "#/definitions/WritebackSettings"
        },
        "writebackDestinations": {
          "description": "List of writeback destinations.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/WritebackDestination"
          }
        }
      }
    },
    "TransformationStep": {
      "title": "TransformationStep",
      "description": "A data transformation step in a query pipeline.",
      "type": "object",
      "required": [
        "stepIndex",
        "meta"
      ],
      "properties": {
        "stepIndex": {
          "description": "The ordinal index of this step.",
          "type": "integer"
        },
        "meta": {
          "description": "Step metadata including type, name, and description.",
          "$ref": "#/definitions/TransformationStepMeta"
        },
        "notes": {
          "description": "Optional notes for the step."
        }
      }
    },
    "TransformationStepMeta": {
      "title": "TransformationStepMeta",
      "description": "Metadata describing a transformation step.",
      "type": "object",
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "description": "The transformation type (e.g., PLANNING, XLSX, or numeric code).",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ]
        },
        "name": {
          "description": "The display name of the step.",
          "type": "string"
        },
        "value": {
          "description": "Step-specific configuration values.",
          "type": "object"
        },
        "description": {
          "description": "A human-readable description of the step.",
          "type": "string"
        }
      }
    },
    "WritebackSettings": {
      "title": "WritebackSettings",
      "description": "Writeback configuration for a query.",
      "type": "object",
      "properties": {
        "writebackMeta": {
          "type": "object",
          "properties": {
            "destinationPreferenceCleared": {
              "type": "boolean"
            },
            "numberPrecision": {
              "type": "object",
              "properties": {
                "decimal": {
                  "type": "integer"
                }
              }
            },
            "stringColumnLength": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "integer"
                },
                "length": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "WritebackDestination": {
      "title": "WritebackDestination",
      "description": "A writeback destination configuration.",
      "type": "object",
      "required": [
        "tableName"
      ],
      "properties": {
        "connection": {
          "$ref": "https://developer.microsoft.com/json-schemas/fabric/common/connectionReference/1.0.0/schema.json#/definitions/ConnectionReferenceOrVar"
        },
        "database": {
          "$ref": "https://developer.microsoft.com/json-schemas/fabric/common/itemReference/1.0.0/schema.json#/definitions/ItemReferenceOrVar"
        },
        "schema": {
          "type": "string"
        },
        "tableName": {
          "type": "string"
        },
        "connectionId": {
          "type": "string"
        },
        "dmtsConnectionId": {
          "description": "Legacy/writeback connection id variable used by connected planning examples.",
          "type": "string"
        },
        "databaseId": {
          "type": "string"
        },
        "connectionIdVariable": {
          "type": "string"
        },
        "settingsHash": {
          "type": "string"
        },
        "settings": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string"
            },
            "database": {
              "type": "string"
            },
            "databaseVariable": {
              "type": "string"
            },
            "schema": {
              "type": "string"
            },
            "dbDisplayName": {
              "type": "string"
            }
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "connection",
            "database"
          ]
        },
        {
          "required": [
            "connectionId",
            "databaseId"
          ]
        },
        {
          "required": [
            "dmtsConnectionId",
            "databaseId"
          ]
        }
      ]
    },
    "QueryGroup": {
      "title": "QueryGroup",
      "description": "A named grouping of queries.",
      "type": "object",
      "required": [
        "name",
        "queryIds"
      ],
      "properties": {
        "name": {
          "description": "The group display name.",
          "type": "string"
        },
        "description": {
          "description": "Optional group description.",
          "type": "string"
        },
        "parentGroupId": {
          "description": "Optional parent group id for hierarchy.",
          "type": "integer"
        },
        "queryIds": {
          "description": "List of query GUIDs belonging to this group.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}