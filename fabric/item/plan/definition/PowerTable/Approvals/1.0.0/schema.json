{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/powerTable/approvals/1.0.0/schema.json",
	"title": "PowerTable Approvals",
	"description": "Approval workflow configuration for a PowerTable visual.",
	"type": "object",
	"required": [
		"$schema",
		"ruleType",
		"persistFlag",
		"approvalLevel",
		"multiLevelEnabled",
		"approvalLevels",
		"approvalFilter",
		"recordGuid"
	],
	"properties": {
		"$schema": {
			"type": "string",
			"format": "uri",
			"const": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/powerTable/approvals/1.0.0/schema.json"
		},
		"ruleType": {
			"type": "integer",
			"description": "Numeric code for approval rule type."
		},
		"persistFlag": {
			"type": "integer",
			"description": "Numeric code controlling persistence behavior."
		},
		"settings": {
			"type": "object",
			"description": "Approval-specific settings payload.",
			"additionalProperties": true
		},
		"approvalLevel": {
			"type": "integer",
			"description": "Current or default approval level."
		},
		"multiLevelEnabled": {
			"type": "integer",
			"description": "Whether multi-level approvals are enabled (0/1).",
			"enum": [
				0,
				1
			]
		},
		"recordGuid": {
			"type": "string",
			"format": "uuid"
		},
		"approvalLevels": {
			"type": "array",
			"description": "Configured approval levels.",
			"items": {
				"$ref": "#/definitions/ApprovalLevel"
			}
		},
		"approvalFilter": {
			"type": "array",
			"description": "Filters applied to approval routing.",
			"items": {
				"$ref": "#/definitions/ApprovalFilter"
			}
		}
	},
	"additionalProperties": false,
	"definitions": {
		"ApprovalLevel": {
			"type": "object",
			"required": [
				"name",
				"description",
				"level",
				"recordGuid"
			],
			"properties": {
				"name": {
					"type": "string"
				},
				"description": {
					"type": "string"
				},
				"level": {
					"type": "integer",
					"minimum": 1
				},
				"recordGuid": {
					"type": "string",
					"format": "uuid"
				}
			},
			"additionalProperties": false
		},
		"ApprovalFilter": {
			"type": "object",
			"required": [
				"name",
				"filter",
				"order",
				"recordGuid"
			],
			"properties": {
				"name": {
					"type": "string"
				},
				"filter": {
					"type": [
						"object",
						"null"
					],
					"additionalProperties": true
				},
				"order": {
					"type": "integer",
					"minimum": 0
				},
				"recordGuid": {
					"type": "string",
					"format": "uuid"
				}
			},
			"additionalProperties": false
		}
	}
}