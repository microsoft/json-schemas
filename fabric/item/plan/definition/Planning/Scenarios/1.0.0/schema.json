{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/planning/scenarios/1.0.0/schema.json",
  "title": "Scenarios",
  "description": "Array of scenario definitions for a Planning visual.",
  "type": "object",
  "required": [
    "$schema",
    "scenarios"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "const": "https://developer.microsoft.com/json-schemas/fabric/item/plan/definition/planning/scenarios/1.0.0/schema.json"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Scenario"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Scenario": {
      "type": "object",
      "required": [
        "name",
        "status",
        "meta"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name of the scenario."
        },
        "status": {
          "type": "string",
          "description": "Current status of the scenario.",
          "enum": [
            "ACTIVE",
            "LOCK"
          ]
        },
        "meta": {
          "$ref": "#/definitions/ScenarioMeta"
        },
        "autoWritebackEnabled": {
          "type": "string",
          "description": "Whether auto-writeback is enabled.",
          "enum": [
            "ACTIVE",
            "INACTIVE"
          ]
        },
        "simulations": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of simulations associated with this scenario.",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "ScenarioMeta": {
      "type": "object",
      "required": [
        "measureIds",
        "scenarioGuid",
        "order"
      ],
      "properties": {
        "measureIds": {
          "type": "array",
          "description": "List of measure IDs included in this scenario.",
          "items": {
            "type": "string"
          }
        },
        "scenarioGuid": {
          "type": "string",
          "description": "Unique identifier for the scenario."
        },
        "order": {
          "type": "integer",
          "description": "Display order of the scenario.",
          "minimum": 0
        },
        "dimensionHash": {
          "type": "string",
          "description": "Hash representing the dimension configuration."
        }
      },
      "additionalProperties": false
    }
  }
}